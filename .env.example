PROMETHEUS_API=http://localhost:9090

# Local Docker Kafka from docker-compose.local-kafka.yml is reachable from the host
# through these ports. Containers use kafka-1:9092,kafka-2:9092,kafka-3:9092.
KAFKA_BROKERS=localhost:19092,localhost:19093,localhost:19094
KAFKA_CLIENT_ID=lighthouse

# Confluent Cloud / SASL clusters
KAFKA_SSL=false
KAFKA_SASL_MECHANISM=plain
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
