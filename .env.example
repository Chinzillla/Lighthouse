# Used only when running the Next.js app directly with npm.
# Docker Compose points Lighthouse at http://prometheus:9090 automatically.
PROMETHEUS_API=http://localhost:9090

# Used by the Kafka metrics exporter. When running the exporter in Docker and
# Kafka is on your host machine, use host.docker.internal instead of localhost.
KAFKA_BROKERS=host.docker.internal:9092
KAFKA_CLIENT_ID=lighthouse

# Plain Kafka can leave KAFKA_SSL blank or false. Confluent Cloud should set true.
KAFKA_SSL=
KAFKA_SASL_MECHANISM=plain
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
