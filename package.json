{
  "name": "lighthouse",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24 <25",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "verify": "npm run audit:prod && npm run lint && npm run test:ci && npm run build",
    "docker:config": "docker compose -f docker-compose.yml config && docker compose -f docker-compose.yml -f docker-compose.local-kafka.yml config",
    "docker:external": "docker compose up --build",
    "docker:external:down": "docker compose down",
    "docker:sample": "docker compose -f docker-compose.yml -f docker-compose.local-kafka.yml up --build",
    "docker:sample:detached": "docker compose -f docker-compose.yml -f docker-compose.local-kafka.yml up --build -d",
    "docker:sample:down": "docker compose -f docker-compose.yml -f docker-compose.local-kafka.yml down",
    "metrics:exporter": "node tools/kafka-metrics-exporter.js",
    "demo:producer": "node tools/kafka-demo-producer.js",
    "replay:cli": "node tools/kafka-replay.js",
    "replay:jobs": "node tools/kafka-replay-jobs.js",
    "test": "jest",
    "test:ci": "jest --runInBand",
    "test:kafka:integration": "jest --runInBand tools/__tests__/kafka-replay.integration.test.js tools/__tests__/kafka-replay-jobs.integration.test.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "chart.js": "^4.5.1",
    "kafkajs": "^2.2.4",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "globals": "^17.5.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-fetch-mock": "^3.0.3",
    "typescript": "^5.9.3"
  }
}
